# Runtime
NODE_ENV=development
PORT=3001
CORS_ORIGIN=http://localhost:5173

# MongoDB (required)
MONGO_URI=mongodb+srv://USER:PASSWORD@CLUSTER/goose_web_dev

# Public assets (Press Kit redirects, etc.)
PUBLIC_ASSET_BASE_URL=http://localhost:5173

# Resend (required)
# Dev: use onboarding@resend.dev as from; notify must be your Resend account email
RESEND_API_KEY=re_REPLACE_ME
RESEND_FROM_EMAIL=onboarding@resend.dev
FEEDBACK_NOTIFY_EMAIL=dev@example.com

# Vote anti-spam (required; secret must be >= 16 chars)
VOTE_IP_HASH_SECRET=dev-only-change-me-16+

# Meta / Oculus unofficial store rating GraphQL (required)
META_APP_ID=REPLACE_ME
OCULUS_GRAPH_ACCESS_TOKEN=REPLACE_ME
OCULUS_GRAPH_DOC_ID=REPLACE_ME
# Optional overrides:
# STORE_RATING_CACHE_TTL_MS=21600000
# OCULUS_GRAPH_ENDPOINT=https://graph.oculus.com/graphql
