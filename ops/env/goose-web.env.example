# Copy to EC2 as /etc/goose-web.env (chmod 640; readable by pm2 user).
# Do NOT commit real secrets. Aligns with web/backend/.env.example + web_backend_express.md §10.4.

NODE_ENV=production
PORT=3002
CORS_ORIGIN=https://www.example.com
MONGO_URI=mongodb+srv://USER:PASSWORD@CLUSTER/goose_web
PUBLIC_ASSET_BASE_URL=https://www.example.com

RESEND_API_KEY=re_REPLACE_ME
RESEND_FROM_EMAIL=onboarding@resend.dev
FEEDBACK_NOTIFY_EMAIL=dev@example.com

VOTE_IP_HASH_SECRET=replace-with-long-random-secret

META_APP_ID=REPLACE_ME
OCULUS_GRAPH_ACCESS_TOKEN=REPLACE_ME
OCULUS_GRAPH_DOC_ID=REPLACE_ME
# STORE_RATING_CACHE_TTL_MS=21600000
# OCULUS_GRAPH_ENDPOINT=https://graph.oculus.com/graphql
